---
import Layout from '../../layouts/Layout.astro';
import ArticleDetailPage from '../../components/ArticleDetailPage';

const articleFiles = import.meta.glob('../../content/articles/*.md', { eager: true, query: '?raw', import: 'default' }) as Record<string, string>;

function parseFrontmatter(raw: string): Record<string, string> {
  const match = raw.match(/^---\n([\s\S]*?)\n---/);
  if (!match) return {};
  const meta: Record<string, string> = {};
  for (const line of match[1].split('\n')) {
    const m = line.match(/^(\w+):\s*"?([^"]*?)"?\s*$/);
    if (m) meta[m[1]] = m[2];
  }
  return meta;
}

const articlesBySlug: Record<string, { title: string; excerpt: string }> = {};
for (const [path, raw] of Object.entries(articleFiles)) {
  const fm = parseFrontmatter(raw);
  const slug = fm.slug || path.split('/').pop()!.replace('.md', '');
  articlesBySlug[slug] = {
    title: fm.title || slug,
    excerpt: fm.excerpt || 'Insights on outbound lead generation for supply chain, logistics, and procurement software.',
  };
}

export function getStaticPaths() {
  const slugs = [
    'cold-calling-connect-rates-by-market',
    'multilingual-calling-doubles-connect-rates',
    'in-house-sdr-math-supply-chain',
  ];
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const article = articlesBySlug[slug!] ?? { title: slug!, excerpt: 'Insights on outbound lead generation for supply chain, logistics, and procurement software.' };
---

<Layout title={`${article.title} | Lynn Lead Gen`} description={article.excerpt} ogImage={`/og/article-${slug}.png`}>
  <ArticleDetailPage client:load slug={slug!} />
</Layout>
